{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerline.dev/schemas/part.schema.json",
  "title": "LedgerLine part",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "part", "measures"],
  "properties": {
    "format": {"const": 1},
    "part": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
    "staves": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["number", "clef"],
        "properties": {
          "number": {"type": "integer", "minimum": 1, "maximum": 32},
          "name": {"type": "string", "minLength": 1},
          "clef": {
            "type": "object",
            "additionalProperties": false,
            "required": ["sign", "line"],
            "properties": {
              "sign": {"enum": ["G", "F", "C", "percussion", "TAB", "none"]},
              "line": {"type": "integer", "minimum": 1, "maximum": 5}
            }
          }
        }
      }
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["at", "type", "controller", "value"],
            "properties": {
              "at": {"type": "string", "pattern": "^[1-9][0-9]*:[1-9][0-9]*(\\.[0-9]+)?$"},
              "type": {"const": "cc"},
              "controller": {
                "type": "integer",
                "minimum": 0,
                "maximum": 127,
                "not": {"enum": [0, 32, 64]}
              },
              "value": {"type": "integer", "minimum": 0, "maximum": 127}
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["at", "type", "action"],
            "properties": {
              "at": {"type": "string", "pattern": "^[1-9][0-9]*:[1-9][0-9]*(\\.[0-9]+)?$"},
              "type": {"const": "pedal"},
              "action": {"enum": ["down", "up", "change"]}
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["at", "type", "name"],
            "properties": {
              "at": {"type": "string", "pattern": "^[1-9][0-9]*:[1-9][0-9]*(\\.[0-9]+)?$"},
              "type": {"const": "keyswitch"},
              "name": {"type": "string", "minLength": 1},
              "velocity": {"type": "integer", "minimum": 1, "maximum": 127},
              "duration": {"type": "string", "pattern": "^1/(1|2|4|8|16|32)\\.{0,2}$"}
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["at", "type", "parameter", "value"],
            "properties": {
              "at": {"type": "string", "pattern": "^[1-9][0-9]*:[1-9][0-9]*(\\.[0-9]+)?$"},
              "type": {"const": "performance"},
              "parameter": {"type": "string", "minLength": 1},
              "value": {"type": "number", "minimum": 0, "maximum": 1}
            }
          }
        ]
      }
    },
    "measures": {
      "type": "object",
      "patternProperties": {
        "^[1-9][0-9]*$": {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^v[1-9][0-9]*$": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["d"],
                "properties": {
                  "p": {
                    "oneOf": [
                      {"type": "string"},
                      {"type": "array", "minItems": 1, "items": {"type": "string"}}
                    ]
                  },
                  "r": {"const": true},
                  "d": {"type": "string", "pattern": "^1/(1|2|4|8|16|32)\\.{0,2}$"},
                  "dyn": {"enum": ["ppp", "pp", "p", "mp", "mf", "f", "ff", "fff"]},
                  "art": {"enum": ["staccato", "tenuto", "accent", "marcato"]},
                  "tie": {"enum": ["start", "stop", "continue"]},
                  "vel": {"type": "integer", "minimum": 1, "maximum": 127},
                  "staff": {"type": "integer", "minimum": 1, "maximum": 32},
                  "expr": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "pitch_cents": {"type": "number", "minimum": -200, "maximum": 200},
                      "curves": {
                        "type": "object",
                        "additionalProperties": false,
                        "properties": {
                          "pitch": {"$ref": "#/$defs/expressionCurve"},
                          "pressure": {"$ref": "#/$defs/expressionCurve"},
                          "timbre": {"$ref": "#/$defs/expressionCurve"}
                        }
                      },
                      "gestures": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "required": ["type"],
                          "properties": {
                            "type": {"enum": ["nonghyeon", "chuseong", "toeseong", "breath", "pluck_position"]},
                            "depth_cents": {"type": "number", "minimum": 0, "maximum": 200},
                            "rate_hz": {"type": "number", "minimum": 0.1, "maximum": 20},
                            "position": {"type": "number", "minimum": 0, "maximum": 1},
                            "amount": {"type": "number", "minimum": 0, "maximum": 1}
                          }
                        }
                      }
                    }
                  }
                },
                "oneOf": [
                  {"required": ["p"], "not": {"required": ["r"]}},
                  {"required": ["r"], "not": {"required": ["p"]}}
                ]
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "expressionCurve": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["at", "value"],
        "properties": {
          "at": {"type": "number", "minimum": 0, "maximum": 1},
          "value": {"type": "number"}
        }
      }
    }
  }
}
