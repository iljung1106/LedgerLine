{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerline.dev/schemas/part.schema.json",
  "title": "LedgerLine part",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "part", "measures"],
  "properties": {
    "format": {"const": 1},
    "part": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
    "measures": {
      "type": "object",
      "patternProperties": {
        "^[1-9][0-9]*$": {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^v[1-9][0-9]*$": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["d"],
                "properties": {
                  "p": {
                    "oneOf": [
                      {"type": "string"},
                      {"type": "array", "minItems": 1, "items": {"type": "string"}}
                    ]
                  },
                  "r": {"const": true},
                  "d": {"type": "string", "pattern": "^1/(1|2|4|8|16|32)\\.{0,2}$"},
                  "dyn": {"enum": ["ppp", "pp", "p", "mp", "mf", "f", "ff", "fff"]},
                  "art": {"enum": ["staccato", "tenuto", "accent", "marcato"]},
                  "tie": {"enum": ["start", "stop", "continue"]},
                  "vel": {"type": "integer", "minimum": 1, "maximum": 127}
                },
                "oneOf": [
                  {"required": ["p"], "not": {"required": ["r"]}},
                  {"required": ["r"], "not": {"required": ["p"]}}
                ]
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}

