{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerline.dev/schemas/studio-state.schema.json",
  "title": "LedgerLine Studio model",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version", "status", "project", "transport", "parts", "notes",
    "profile_catalog", "controls", "automation", "mix", "score", "media", "build", "refinement",
    "delegations", "capabilities"
  ],
  "properties": {
    "schema_version": {"const": "2"},
    "status": {"const": "ok"},
    "project": {
      "type": "object",
      "required": ["root", "title", "revision"],
      "properties": {
        "root": {"type": "string"},
        "title": {"type": "string"},
        "revision": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "parts": {"type": "array", "items": {"type": "object"}},
    "profile_catalog": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "source", "status"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "family": {"type": "string", "minLength": 1},
          "source": {"enum": ["built-in", "project"]},
          "status": {"enum": ["ready", "error"]},
          "reason": {"type": "string"},
          "diagnostics": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["severity", "code", "path", "message"],
              "properties": {
                "severity": {"enum": ["error", "warning", "info"]},
                "code": {"type": "string", "minLength": 1},
                "path": {"type": "string"},
                "message": {"type": "string", "minLength": 1}
              }
            }
          },
          "range": {"type": "object"},
          "midi": {"type": "object"},
          "midi_preset": {"type": "object"},
          "articulations": {"type": "array", "items": {"type": "string"}},
          "keyswitches": {"type": "array", "items": {"type": "string"}},
          "keyswitch_map": {"type": "object"},
          "performance_parameters": {"type": "array", "items": {"type": "string"}},
          "performance": {"type": "object"}
        },
        "allOf": [
          {
            "if": {"properties": {"status": {"const": "ready"}}},
            "then": {
              "required": [
                "name", "family", "range", "midi", "midi_preset", "articulations",
                "keyswitches", "keyswitch_map", "performance_parameters", "performance"
              ]
            },
            "else": {"required": ["reason", "diagnostics"]}
          }
        ]
      }
    },
    "transport": {
      "type": "object",
      "required": ["duration_seconds", "tempo_segments", "measures"],
      "properties": {
        "duration_seconds": {"type": "number", "minimum": 0},
        "tempo_segments": {"type": "array", "items": {"type": "object"}},
        "measures": {"type": "array", "items": {"type": "object"}}
      }
    },
    "notes": {"type": "array", "items": {"type": "object"}},
    "controls": {"type": "array", "items": {"type": "object"}},
    "tempo": {"type": "array", "items": {"type": "object"}},
    "automation": {"type": "array", "items": {"type": "object"}},
    "mix": {"type": "object"},
    "score": {"type": "object", "required": ["url"]},
    "media": {"type": "object"},
    "build": {"type": "object"},
    "refinement": {
      "type": "object",
      "required": ["status", "url"],
      "properties": {
        "status": {"enum": ["missing", "ready", "stale"]},
        "url": {"type": ["string", "null"]},
        "authored_revision": {"type": ["string", "null"]},
        "output_sha256": {"type": ["string", "null"]}
      }
    },
    "capabilities": {"type": "object"},
    "history": {"type": "object"},
    "delegations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "proposal_preview": {
            "anyOf": [
              {"type": "null"},
              {"$ref": "#/$defs/proposalPreview"}
            ]
          }
        }
      }
    },
    "csrf_token": {"type": "string"}
  },
  "$defs": {
    "proposalPreview": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version", "status", "base_revision", "result_revision",
        "impact", "yaml_diff", "score_diff"
      ],
      "properties": {
        "schema_version": {"const": "1"},
        "status": {"enum": ["ready", "no-actions"]},
        "base_revision": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "result_revision": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "impact": {
          "type": "object",
          "required": [
            "changed", "files", "parts", "measures", "aspects",
            "targets", "fields", "counts"
          ],
          "properties": {
            "changed": {"type": "boolean"},
            "files": {"type": "array", "items": {"type": "object"}},
            "parts": {"type": "array", "items": {"type": "string"}},
            "measures": {"type": "array", "items": {"type": "object"}},
            "aspects": {"type": "array", "items": {"type": "string"}},
            "targets": {"type": "array", "items": {"type": "string"}},
            "fields": {"type": "array", "items": {"type": "string"}},
            "counts": {"type": "object"}
          }
        },
        "yaml_diff": {
          "type": "object",
          "required": ["format", "text", "truncated", "limits"],
          "properties": {
            "format": {"const": "unified-yaml"},
            "text": {"type": "string"},
            "truncated": {"type": "boolean"},
            "limits": {"type": "object"}
          }
        },
        "score_diff": {
          "type": "object",
          "required": ["identity", "added", "removed", "changed", "counts"],
          "properties": {
            "identity": {"type": "object"},
            "added": {"type": "array", "items": {"type": "object"}},
            "removed": {"type": "array", "items": {"type": "object"}},
            "changed": {"type": "array", "items": {"type": "object"}},
            "counts": {"type": "object"}
          }
        }
      }
    }
  }
}
