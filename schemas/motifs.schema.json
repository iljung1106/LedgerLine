{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerline.dev/schemas/motifs.schema.json",
  "title": "LedgerLine motifs",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "motifs", "placements"],
  "properties": {
    "format": {"const": 1},
    "motifs": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["events"],
        "properties": {"events": {"type": "array", "minItems": 1}}
      }
    },
    "placements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["motif", "part", "measure"],
        "properties": {
          "motif": {"type": "string"},
          "part": {"type": "string"},
          "measure": {"type": "integer", "minimum": 1},
          "voice": {"type": "string", "pattern": "^v[0-9]+$"},
          "mode": {"enum": ["replace", "append"]},
          "transform": {"type": "array", "items": {"type": "object"}}
        }
      }
    }
  }
}
