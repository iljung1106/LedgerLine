{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerline.dev/schemas/render.schema.json",
  "title": "LedgerLine render graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "nodes"],
  "properties": {
    "format": {"const": 1},
    "sample_rate": {"type": "integer", "minimum": 8000, "maximum": 384000},
    "block_size": {"type": "integer", "minimum": 16, "maximum": 16384},
    "tail_seconds": {"type": "number", "minimum": 0, "maximum": 600},
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_render_seconds": {"type": "number", "minimum": 1, "maximum": 86400},
        "max_stem_mb": {"type": "number", "minimum": 1},
        "max_cache_mb": {"type": "number", "minimum": 1}
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "part", "engine", "instrument"],
        "allOf": [
          {
            "if": {"properties": {"engine": {"const": "frozen"}}},
            "then": {"not": {"required": ["executable"]}},
            "else": {"required": ["executable"]}
          }
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "part": {"type": "string", "minLength": 1},
          "engine": {"enum": ["fluidsynth", "sfizz", "plugin", "frozen"]},
          "executable": {"type": "string", "minLength": 1},
          "arguments": {"type": "array", "items": {"type": "string"}},
          "instrument": {"type": "string", "minLength": 1},
          "plugin_format": {"enum": ["vst3", "clap"]},
          "state": {"type": "string", "minLength": 1},
          "latency_samples": {"type": "integer", "minimum": 0},
          "tail_seconds": {"type": "number", "minimum": 0, "maximum": 600}
        }
      }
    }
  }
}
