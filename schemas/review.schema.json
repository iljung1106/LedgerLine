{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerline.dev/schemas/review.schema.json",
  "title": "LedgerLine listening annotations",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "annotations"],
  "properties": {
    "format": {"const": 1},
    "annotations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "at", "message"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
          "at": {"type": "string"},
          "end": {"type": "string"},
          "category": {"enum": ["composition", "orchestration", "performance", "mix", "render", "other"]},
          "severity": {"enum": ["note", "warning", "blocking"]},
          "message": {"type": "string", "minLength": 1},
          "parts": {"type": "array", "items": {"type": "string"}},
          "status": {"enum": ["open", "resolved", "wontfix"]}
        }
      }
    }
  }
}
