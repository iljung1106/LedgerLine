{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerline.dev/schemas/brief.schema.json",
  "title": "LedgerLine creative brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format", "trajectory", "sections", "roles", "protected",
    "style_checks", "invariants", "checkpoints"
  ],
  "properties": {
    "format": {"const": 1},
    "purpose": {"type": "string", "minLength": 1},
    "duration_seconds": {"type": "number", "exclusiveMinimum": 0},
    "trajectory": {"$ref": "#/$defs/nonEmptyStrings"},
    "references": {"$ref": "#/$defs/strings"},
    "required_instruments": {"$ref": "#/$defs/strings"},
    "forbidden_sounds": {"$ref": "#/$defs/strings"},
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "from", "to", "function"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "from": {"$ref": "#/$defs/anchor"},
          "to": {"$ref": "#/$defs/anchor"},
          "function": {"type": "string", "minLength": 1}
        }
      }
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["part", "from", "to", "role"],
        "properties": {
          "part": {"type": "string", "minLength": 1},
          "from": {"$ref": "#/$defs/anchor"},
          "to": {"$ref": "#/$defs/anchor"},
          "role": {"type": "string", "minLength": 1}
        }
      }
    },
    "protected": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "parts", "aspects"],
        "properties": {
          "from": {"$ref": "#/$defs/anchor"},
          "to": {"$ref": "#/$defs/anchor"},
          "parts": {"$ref": "#/$defs/nonEmptyStrings"},
          "aspects": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "pitch", "rhythm", "dynamics", "articulation",
                "expression", "instrument", "mix"
              ]
            }
          }
        }
      }
    },
    "style_checks": {
      "type": "object",
      "additionalProperties": {"enum": ["off", "review"]}
    },
    "invariants": {"$ref": "#/$defs/strings"},
    "checkpoints": {"$ref": "#/$defs/nonEmptyStrings"}
  },
  "$defs": {
    "anchor": {
      "type": "string",
      "pattern": "^[1-9][0-9]*:(?:[1-9][0-9]*(?:\\.[0-9]+)?|end)$"
    },
    "strings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
