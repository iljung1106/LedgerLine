{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ledgerline.dev/schemas/automation.schema.json",
  "title": "LedgerLine automation",
  "type": "object",
  "additionalProperties": false,
  "required": ["format", "lanes"],
  "properties": {
    "format": {"const": 1},
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "target", "points"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z][a-z0-9_-]*$"},
          "target": {"type": "string", "pattern": "^(parts|buses|master)\\.[A-Za-z0-9_.-]+$"},
          "unit": {"enum": ["normalized", "db", "percent", "pan", "hz", "semitones", "cents", "native"]},
          "interpolation": {"enum": ["step", "linear", "smooth", "exponential", "bezier"]},
          "points": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["at", "value"],
              "properties": {
                "at": {"type": "string"},
                "value": {"type": "number"},
                "curve": {"enum": ["step", "linear", "smooth", "exponential", "bezier"]},
                "in_value": {"type": "number"},
                "out_value": {"type": "number"}
              }
            }
          }
        }
      }
    }
  }
}
